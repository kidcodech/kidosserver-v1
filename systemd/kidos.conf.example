# Kidos System Configuration
# Copy this file to /etc/kidos/config and edit as needed

# WAN interface (internet uplink, stays in root namespace, bridged via br-wan)
# Leave empty for auto-detect via default route
WAN_INTERFACE=""

# LAN interface (wired client port, moved to switchns for DNS filtering)
ETHERNET_INTERFACE=""

# Hotspot settings (WiFi AP mode only)
HOTSPOT_AUTOSTART=false
HOTSPOT_SSID=KidosNet
HOTSPOT_PASSWORD=kidos123
HOTSPOT_CHANNEL=6
